#!/usr/bin/env bash
# mlx-server — manage one or more local mlx_lm.server instances
#
# Usage:
#   mlx-server start [model] [--port N] [--max-tokens N] [--thinking] [...]
#   mlx-server stop  [model|--port N]   (omit to stop all)
#   mlx-server status
#   mlx-server list
#   mlx-server logs  [model|--port N] [-f]
#
# Examples:
#   mlx-server start
#   mlx-server start mlx-community/Qwen3-8B-4bit --port 8089
#   mlx-server start mlx-community/Qwen3-32B-4bit --port 8088
#   mlx-server stop mlx-community/Qwen3-8B-4bit
#   mlx-server stop --port 8089
#   mlx-server stop                        # stops all
#   mlx-server status
#   mlx-server logs mlx-community/Qwen3-32B-4bit -f

set -eo pipefail

# ── Defaults ────────────────────────────────────────────────────────────────
DEFAULT_MODEL="mlx-community/Qwen3-32B-4bit"
DEFAULT_PORT="8088"
DEFAULT_MAX_TOKENS="4096"
MLX_BIN="mlx_lm.server"

MLX_HOME="${HOME}/.mlx"
mkdir -p "${MLX_HOME}"

# ── Helpers ─────────────────────────────────────────────────────────────────
_require_mlx() {
  if ! command -v "${MLX_BIN}" &>/dev/null; then
    echo "Error: mlx_lm.server not found. Install with: pipx install mlx-lm" >&2
    exit 1
  fi
}

# Returns the PID file path for a given port
_pid_file()  { echo "${MLX_HOME}/server-${1}.pid"; }
_log_file()  { echo "${MLX_HOME}/server-${1}.log"; }
_meta_file() { echo "${MLX_HOME}/server-${1}.meta"; }  # stores model name

# Returns the live PID for a port, or empty if not running
_pid_for_port() {
  local pf; pf=$(_pid_file "${1}")
  [[ -f "${pf}" ]] || return 1
  local pid; pid=$(cat "${pf}")
  kill -0 "${pid}" 2>/dev/null && echo "${pid}" || { rm -f "${pf}"; return 1; }
}

# Finds the port for a given model name (first match)
_port_for_model() {
  local model="${1}"
  for meta in "${MLX_HOME}"/server-*.meta; do
    [[ -f "${meta}" ]] || continue
    if grep -q "^model=${model}$" "${meta}" 2>/dev/null; then
      local port; port=$(grep "^port=" "${meta}" | cut -d= -f2)
      _pid_for_port "${port}" &>/dev/null && echo "${port}" && return 0
    fi
  done
  return 1
}

# List all running instances: "port model pid tracked"
# Also detects orphan mlx_lm.server processes not started via this script
_running_instances() {
  local seen_pids=()

  # Tracked instances (via PID files)
  for meta in "${MLX_HOME}"/server-*.meta; do
    [[ -f "${meta}" ]] || continue
    local port; port=$(grep "^port=" "${meta}" | cut -d= -f2)
    local model; model=$(grep "^model=" "${meta}" | cut -d= -f2)
    local pid; pid=$(_pid_for_port "${port}" 2>/dev/null) || continue
    echo "${port} ${model} ${pid} tracked"
    seen_pids+=("${pid}")
  done

  # Orphan instances: mlx_lm.server processes not in our PID files
  while IFS= read -r line; do
    local pid; pid=$(echo "${line}" | awk '{print $2}')
    # Skip if already tracked
    local already=false
    for sp in "${seen_pids[@]+"${seen_pids[@]}"}"; do
      [[ "${sp}" == "${pid}" ]] && already=true && break
    done
    [[ "${already}" == true ]] && continue

    local model; model=$(echo "${line}" | grep -o -- '--model [^ ]*' | awk '{print $2}')
    local port; port=$(echo "${line}" | grep -o -- '--port [^ ]*' | awk '{print $2}')
    [[ -z "${port}" ]] && port="unknown"
    [[ -z "${model}" ]] && model="unknown"
    echo "${port} ${model} ${pid} orphan"
  done < <(ps aux | grep '[m]lx_lm.server')
}

_print_usage() {
  cat <<EOF
Usage: mlx-server <command> [options]

Commands:
  start [model] [options]         Start an MLX inference server instance
  stop  [model | --port N]        Stop a specific instance (or all if omitted)
  status                          Show all running instances
  list                            Alias for status
  models                          List locally downloaded MLX models
  search [query]                  Search mlx-community models on HuggingFace
  logs  [model | --port N] [-f]   View logs for an instance

Start options:
  model                     HuggingFace model ID  (default: ${DEFAULT_MODEL})
  --port N                  Port to listen on      (default: ${DEFAULT_PORT})
  --max-tokens N            Max tokens per response (default: ${DEFAULT_MAX_TOKENS})
  --thinking                Enable chain-of-thought (disabled by default)
  Any extra flags are passed directly to mlx_lm.server

Examples:
  mlx-server start
  mlx-server start mlx-community/Qwen3-8B-4bit --port 8089
  mlx-server start mlx-community/Qwen3-32B-4bit --port 8088 --max-tokens 8192
  mlx-server stop mlx-community/Qwen3-8B-4bit
  mlx-server stop --port 8089
  mlx-server stop                               # stops all instances
  mlx-server status
  mlx-server models
  mlx-server search Qwen3
  mlx-server search llama 32b
  mlx-server logs mlx-community/Qwen3-32B-4bit -f
EOF
}

# ── Commands ─────────────────────────────────────────────────────────────────
cmd_start() {
  _require_mlx

  local model="${DEFAULT_MODEL}"
  local port="${DEFAULT_PORT}"
  local max_tokens="${DEFAULT_MAX_TOKENS}"
  local thinking=false
  local extra_args=()

  # First positional arg (if not a flag) is the model
  if [[ $# -gt 0 && "${1}" != --* ]]; then
    model="${1}"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --port)          port="${2}"; shift 2 ;;
      --port=*)        port="${1#*=}"; shift ;;
      --max-tokens)    max_tokens="${2}"; shift 2 ;;
      --max-tokens=*)  max_tokens="${1#*=}"; shift ;;
      --thinking)      thinking=true; shift ;;
      *)               extra_args+=("${1}"); shift ;;
    esac
  done

  # Check if something is already on this port (tracked or not)
  if pid=$(_pid_for_port "${port}" 2>/dev/null); then
    local existing; existing=$(grep "^model=" "$(_meta_file "${port}")" 2>/dev/null | cut -d= -f2 || echo "unknown")
    echo "Port ${port} is already tracked as '${existing}' (PID ${pid})."
    echo "Stop it first: mlx-server stop --port ${port}"
    exit 1
  fi
  if curl -s --max-time 2 "http://127.0.0.1:${port}/v1/models" &>/dev/null; then
    echo "Port ${port} is already in use by an untracked process."
    echo "Run 'mlx-server status' to see it, then stop it manually or choose a different --port."
    exit 1
  fi

  local thinking_arg=()
  [[ "${thinking}" == false ]] && thinking_arg=(--chat-template-args '{"enable_thinking":false}')

  echo "Starting mlx-server..."
  echo "  Model:      ${model}"
  echo "  Port:       ${port}"
  echo "  Max tokens: ${max_tokens}"
  echo "  Thinking:   ${thinking}"
  [[ ${#extra_args[@]} -gt 0 ]] && echo "  Extra args: ${extra_args[*]}"
  echo "  Logs:       $(_log_file "${port}")"
  echo ""

  nohup env HF_HUB_OFFLINE=1 "${MLX_BIN}" \
    --model "${model}" \
    --port "${port}" \
    --max-tokens "${max_tokens}" \
    "${thinking_arg[@]}" \
    ${extra_args[@]+"${extra_args[@]}"} \
    > "$(_log_file "${port}")" 2>&1 &

  local pid=$!
  disown "${pid}"
  echo "${pid}" > "$(_pid_file "${port}")"
  printf "port=%s\nmodel=%s\n" "${port}" "${model}" > "$(_meta_file "${port}")"

  echo -n "Waiting for server to load"
  local waited=0
  while ! curl -s "http://127.0.0.1:${port}/v1/models" &>/dev/null; do
    sleep 3; waited=$((waited + 3)); echo -n "."
    if [[ ${waited} -ge 300 ]]; then
      echo ""; echo "Timeout. Check logs: mlx-server logs --port ${port}"; exit 1
    fi
  done

  echo ""
  echo "✅ mlx-server ready  →  http://127.0.0.1:${port}  (${model})"
}

cmd_stop() {
  # Resolve target port
  local port=""

  if [[ $# -eq 0 ]]; then
    # Stop all
    local found=0
    while IFS=" " read -r p m; do
      local pid; pid=$(_pid_for_port "${p}")
      echo "Stopping '${m}' on port ${p} (PID ${pid})..."
      kill "${pid}"; rm -f "$(_pid_file "${p}")" "$(_meta_file "${p}")"
      found=$((found + 1))
    done < <(_running_instances)
    [[ ${found} -eq 0 ]] && echo "No running mlx-server instances." || echo "✅ Stopped ${found} instance(s)."
    return 0
  fi

  case "${1}" in
    --port)    port="${2}" ;;
    --port=*)  port="${1#*=}" ;;
    *)
      # Treat arg as model name
      port=$(_port_for_model "${1}") || { echo "No running instance found for model '${1}'."; exit 1; }
      ;;
  esac

  local pid; pid=$(_pid_for_port "${port}" 2>/dev/null) || {
    # Try to find orphan process on this port
    local orphan_pid; orphan_pid=$(ps aux | grep '[m]lx_lm.server' | grep -- "--port ${port}" | awk '{print $2}' | head -1)
    if [[ -n "${orphan_pid}" ]]; then
      echo "Stopping untracked process on port ${port} (PID ${orphan_pid})..."
      kill "${orphan_pid}" && echo "✅ Stopped."
      return 0
    fi
    echo "No running instance on port ${port}."; exit 1
  }
  local model; model=$(grep "^model=" "$(_meta_file "${port}")" 2>/dev/null | cut -d= -f2 || echo "unknown")
  echo "Stopping '${model}' on port ${port} (PID ${pid})..."
  kill "${pid}"
  rm -f "$(_pid_file "${port}")" "$(_meta_file "${port}")"
  echo "✅ Stopped."
}

cmd_status() {
  local instances; instances=$(_running_instances)
  if [[ -z "${instances}" ]]; then
    echo "⏹  No mlx-server instances running."
    return 0
  fi

  printf "%-8s  %-45s  %-10s  %s\n" "PORT" "MODEL" "PID" "STATUS"
  printf "%-8s  %-45s  %-10s  %s\n" "--------" "---------------------------------------------" "----------" "------"
  while IFS=" " read -r port model pid tracked; do
    if [[ "${tracked}" == "orphan" ]]; then
      printf "%-8s  %-45s  %-10s  ⚠️  running (untracked — started outside mlx-server)\n" "${port}" "${model}" "${pid}"
    else
      printf "%-8s  %-45s  %-10s  ✅ running\n" "${port}" "${model}" "${pid}"
    fi
  done <<< "${instances}"
}

cmd_models() {
  local hf_cache="${HF_HOME:-${HOME}/.cache/huggingface}/hub"
  if [[ ! -d "${hf_cache}" ]]; then
    echo "No HuggingFace cache found at ${hf_cache}"
    return 0
  fi

  # Collect running instances for status column
  local running_info; running_info=$(_running_instances)

  local found=0
  printf "%-50s  %-8s  %s\n" "MODEL" "SIZE" "STATUS"
  printf "%-50s  %-8s  %s\n" "--------------------------------------------------" "--------" "------"

  for dir in "${hf_cache}"/models--*; do
    [[ -d "${dir}" ]] || continue
    local dir_name; dir_name=$(basename "${dir}")
    local model_id; model_id=$(echo "${dir_name}" | sed 's/^models--//' | sed 's/--/\//g')

    local size; size=$(du -sh "${dir}" 2>/dev/null | awk '{print $1}')
    local status="⏹  not running"
    local port; port=$(echo "${running_info}" | awk -v m="${model_id}" '$2==m {print $1}')
    [[ -n "${port}" ]] && status="✅ running on :${port}"

    printf "%-50s  %-8s  %s\n" "${model_id}" "${size}" "${status}"
    found=$((found + 1))
  done

  if [[ ${found} -eq 0 ]]; then
    echo "No models found in ${hf_cache}"
  fi
}

cmd_search() {
  local query="${*:-}"
  local limit=20
  local url="https://huggingface.co/api/models?author=mlx-community&sort=downloads&limit=${limit}"
  [[ -n "${query}" ]] && url="${url}&search=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "${query}")"

  echo "Searching mlx-community models${query:+ for \"${query}\"}..."
  echo ""

  local response
  if ! response=$(curl -sf --max-time 10 "${url}"); then
    echo "Error: Could not reach HuggingFace API. Check your internet connection." >&2
    exit 1
  fi

  # Get local cache list for downloaded indicator
  local hf_cache="${HF_HOME:-${HOME}/.cache/huggingface}/hub"

  python3 - <<PYEOF
import json, os, sys

data = json.loads('''${response}''')
hf_cache = "${hf_cache}"

def cache_dir(model_id):
    return os.path.join(hf_cache, "models--" + model_id.replace("/", "--"))

def fmt_downloads(n):
    if n >= 1_000_000: return f"{n/1_000_000:.1f}M"
    if n >= 1_000: return f"{n/1_000:.0f}k"
    return str(n)

print(f"{'MODEL':<52}  {'DOWNLOADS':>9}  {'LOCAL'}")
print(f"{'-'*52}  {'-'*9}  {'-'*5}")
for m in data:
    mid = m["id"]
    dl = fmt_downloads(m.get("downloads", 0))
    local = "✅" if os.path.isdir(cache_dir(mid)) else ""
    print(f"{mid:<52}  {dl:>9}  {local}")

print(f"\nShowing top {len(data)} results. Use 'mlx-server start <model>' to run one.")
PYEOF
}

cmd_logs() {
  local port=""
  local follow=false

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --port)    port="${2}"; shift 2 ;;
      --port=*)  port="${1#*=}"; shift ;;
      -f)        follow=true; shift ;;
      *)
        # Treat as model name
        port=$(_port_for_model "${1}") || { echo "No running instance for model '${1}'."; exit 1; }
        shift ;;
    esac
  done

  # Default: first running instance
  if [[ -z "${port}" ]]; then
    port=$(_running_instances | awk '{print $1; exit}')
    [[ -z "${port}" ]] && { echo "No running instances. Specify --port N."; exit 1; }
  fi

  local log; log=$(_log_file "${port}")
  [[ -f "${log}" ]] || { echo "No log file found for port ${port}."; exit 1; }
  [[ "${follow}" == true ]] && tail -f "${log}" || tail -50 "${log}"
}

# ── Entry point ──────────────────────────────────────────────────────────────
case "${1:-}" in
  start)        shift; cmd_start "$@" ;;
  stop)         shift; cmd_stop "$@" ;;
  status|list)  shift; cmd_status ;;
  models)       shift; cmd_models ;;
  search)       shift; cmd_search "$@" ;;
  logs)         shift; cmd_logs "$@" ;;
  -h|--help|help|"") _print_usage ;;
  *) echo "Unknown command: ${1}"; echo ""; _print_usage; exit 1 ;;
esac
