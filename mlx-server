#!/usr/bin/env bash
# mlx-server — Ollama-style CLI for managing local MLX inference on Apple Silicon
set -eo pipefail

# ── Resolve script directory (follows symlinks) ─────────────────────────────
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# ── Configuration ────────────────────────────────────────────────────────────
GATEWAY_SCRIPT="${SCRIPT_DIR}/mlx_gateway.py"
GATEWAY_PORT="${MLX_PORT:-11070}"
GATEWAY_URL="http://127.0.0.1:${GATEWAY_PORT}"
MLX_HOME="${HOME}/.mlx"
HF_CACHE="${HF_HOME:-${HOME}/.cache/huggingface}/hub"
mkdir -p "${MLX_HOME}"

# ── Helpers ──────────────────────────────────────────────────────────────────

_gateway_pid() {
  local pf="${MLX_HOME}/gateway.pid"
  [[ -f "${pf}" ]] || return 1
  local pid; pid=$(cat "${pf}")
  kill -0 "${pid}" 2>/dev/null && echo "${pid}" || { rm -f "${pf}"; return 1; }
}

_require_gateway() {
  _gateway_pid &>/dev/null || {
    echo "mlx-server is not running. Start it with: mlx-server serve"
    exit 1
  }
}

_ensure_gateway() {
  # Auto-start gateway if not running
  if ! _gateway_pid &>/dev/null; then
    cmd_serve --quiet
  fi
}

_api() {
  local method="${1}" path="${2}" body="${3:-}"
  if [[ -n "${body}" ]]; then
    curl -sf --max-time 600 -X "${method}" "${GATEWAY_URL}${path}" \
      -H "Content-Type: application/json" -d "${body}" 2>/dev/null
  else
    curl -sf --max-time 10 -X "${method}" "${GATEWAY_URL}${path}" 2>/dev/null
  fi
}

_model_cache_dir() {
  echo "${HF_CACHE}/models--$(echo "${1}" | sed 's|/|--|g')"
}

_find_mlx_python() {
  # Get the Python interpreter from the mlx_lm.server shebang
  local mlx_bin; mlx_bin=$(which mlx_lm.server 2>/dev/null || echo "")
  if [[ -n "${mlx_bin}" ]]; then
    local shebang; shebang=$(head -1 "${mlx_bin}" | sed 's/^#! *//')
    if [[ -x "${shebang}" ]]; then
      echo "${shebang}"
      return 0
    fi
  fi
  echo "python3"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_serve() {
  local quiet=false
  local port="${GATEWAY_PORT}"

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --port)    port="${2}"; shift 2 ;;
      --port=*)  port="${1#*=}"; shift ;;
      --quiet)   quiet=true; shift ;;
      *)         shift ;;
    esac
  done

  if _gateway_pid &>/dev/null; then
    [[ "${quiet}" == false ]] && echo "mlx-server is already running (PID $(_gateway_pid)) on ${GATEWAY_URL}"
    return 0
  fi

  [[ "${quiet}" == false ]] && echo "Starting mlx-server on port ${port}..."

  nohup python3 "${GATEWAY_SCRIPT}" --port "${port}" \
    >> "${MLX_HOME}/gateway.log" 2>&1 &
  local pid=$!
  disown "${pid}"

  # Wait for ready
  [[ "${quiet}" == false ]] && echo -n "Waiting"
  for _ in $(seq 1 30); do
    if curl -sf --max-time 1 "http://127.0.0.1:${port}/_/health" &>/dev/null; then
      [[ "${quiet}" == false ]] && echo ""
      [[ "${quiet}" == false ]] && echo "✅ mlx-server running on http://127.0.0.1:${port}"
      [[ "${quiet}" == false ]] && echo ""
      [[ "${quiet}" == false ]] && echo "API:  http://127.0.0.1:${port}/v1/"
      [[ "${quiet}" == false ]] && echo ""
      [[ "${quiet}" == false ]] && echo "Next steps:"
      [[ "${quiet}" == false ]] && echo "  mlx-server run <model>              Load a model and chat"
      [[ "${quiet}" == false ]] && echo "  mlx-server ps                       Show loaded models"
      [[ "${quiet}" == false ]] && echo "  mlx-server shutdown                 Stop everything"
      return 0
    fi
    sleep 1
    [[ "${quiet}" == false ]] && echo -n "."
  done

  [[ "${quiet}" == false ]] && echo ""
  echo "❌ Gateway failed to start. Check: mlx-server logs" >&2
  exit 1
}

cmd_run() {
  local model="${1:-}"
  [[ -z "${model}" ]] && { echo "Usage: mlx-server run <model>"; exit 1; }

  _ensure_gateway

  # Auto-pull if not cached
  local cache_dir; cache_dir=$(_model_cache_dir "${model}")
  if [[ ! -d "${cache_dir}" ]]; then
    echo "Model not found locally. Pulling first..."
    cmd_pull "${model}" || exit 1
  fi

  # Load model via gateway
  _api POST "/_/load" "{\"model\":\"${model}\"}" > /dev/null

  # Wait for ready
  echo -n "Loading ${model}"
  for _ in $(seq 1 200); do
    local ps_resp
    ps_resp=$(_api GET "/_/ps") || { sleep 3; echo -n "."; continue; }
    # Check for failure first
    local failed_err
    failed_err=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m['model'] == sys.argv[1] and m.get('failed'):
        print(m.get('error', 'Unknown error'))
        sys.exit(0)
sys.exit(1)
" "${model}" <<< "${ps_resp}" 2>/dev/null) && {
      echo ""
      echo "❌ Failed to load ${model}:" >&2
      echo "   ${failed_err}" >&2
      echo ""
      echo "Tip: This model may not be a text-generation model supported by mlx_lm." >&2
      echo "     Check: mlx-server logs" >&2
      exit 1
    }
    if python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m['model'] == sys.argv[1] and m.get('ready'):
        sys.exit(0)
sys.exit(1)
" "${model}" <<< "${ps_resp}" 2>/dev/null; then
      echo ""
      echo "✅ ${model} ready"
      echo ""
      # Check model type - embedding models don't have a chat REPL
      local model_type
      model_type=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m['model'] == sys.argv[1]:
        print(m.get('type', 'llm'))
        sys.exit(0)
print('llm')
" "${model}" <<< "${ps_resp}" 2>/dev/null)
      if [[ "${model_type}" == "embedding" ]]; then
        echo "Embedding model loaded. Use POST /v1/embeddings to generate embeddings."
        echo "Example:"
        echo "  curl http://127.0.0.1:11070/v1/embeddings \\"
        echo "    -H 'Content-Type: application/json' \\"
        echo "    -d '{\"model\":\"${model}\",\"input\":\"Your text here\"}'"
      else
        # Start interactive chat
        python3 "${GATEWAY_SCRIPT}" chat "${GATEWAY_URL}" "${model}"
      fi
      return 0
    fi
    sleep 3
    echo -n "."
  done

  echo ""
  echo "❌ Timed out loading model. Check: mlx-server logs" >&2
  exit 1
}

cmd_stop() {
  _require_gateway
  local model="${1:-}"
  [[ -z "${model}" ]] && { echo "Usage: mlx-server stop <model>"; exit 1; }

  local resp
  resp=$(_api POST "/_/unload" "{\"model\":\"${model}\"}")
  if [[ $? -eq 0 ]]; then
    echo "✅ Stopped ${model}"
  else
    echo "Model '${model}' is not loaded."
  fi
}

cmd_pull() {
  local model="${1:-}"
  [[ -z "${model}" ]] && { echo "Usage: mlx-server pull <model>"; exit 1; }

  local cache_dir; cache_dir=$(_model_cache_dir "${model}")
  if [[ -d "${cache_dir}" ]]; then
    echo "${model} is already downloaded."
    return 0
  fi

  echo "Pulling ${model}..."
  local mlx_python; mlx_python=$(_find_mlx_python)

  "${mlx_python}" -c "
from huggingface_hub import snapshot_download
import sys
model = sys.argv[1]
print(f'Downloading {model}...')
snapshot_download(model)
print(f'✅ {model} pulled successfully')
" "${model}"
}

cmd_rm() {
  local model="${1:-}"
  [[ -z "${model}" ]] && { echo "Usage: mlx-server rm <model>"; exit 1; }

  local cache_dir; cache_dir=$(_model_cache_dir "${model}")

  if [[ ! -d "${cache_dir}" ]]; then
    echo "Model '${model}' not found locally."
    exit 1
  fi

  # Unload from gateway if running
  if _gateway_pid &>/dev/null; then
    _api POST "/_/unload" "{\"model\":\"${model}\"}" &>/dev/null || true
  fi

  local size; size=$(du -sh "${cache_dir}" 2>/dev/null | awk '{print $1}')
  echo "Removing ${model} (${size})..."
  rm -rf "${cache_dir}"
  echo "✅ Removed."
}

cmd_show() {
  local model="${1:-}"
  [[ -z "${model}" ]] && { echo "Usage: mlx-server show <model>"; exit 1; }

  local cache_dir; cache_dir=$(_model_cache_dir "${model}")

  if [[ ! -d "${cache_dir}" ]]; then
    echo "Model '${model}' not found locally."
    echo "Pull it first: mlx-server pull ${model}"
    exit 1
  fi

  local size; size=$(du -sh "${cache_dir}" 2>/dev/null | awk '{print $1}')

  echo "  Model:     ${model}"
  echo "  Size:      ${size}"
  echo "  Location:  ${cache_dir}"
  echo ""

  # Parse config.json for model details
  local config
  config=$(find "${cache_dir}" -name "config.json" -path "*/snapshots/*" | head -1)

  if [[ -n "${config}" && -f "${config}" ]]; then
    echo "  Configuration:"
    python3 -c "
import json, sys

with open(sys.argv[1]) as f:
    c = json.load(f)

arch = c.get('model_type', 'unknown')
if arch == 'unknown' and 'architectures' in c:
    arch = c['architectures'][0]

hidden = c.get('hidden_size', '-')
layers = c.get('num_hidden_layers', '-')
heads = c.get('num_attention_heads', '-')
ctx = c.get('max_position_embeddings', c.get('sliding_window', '-'))
vocab = c.get('vocab_size', '-')

quant = '-'
if isinstance(c.get('quantization'), dict):
    bits = c['quantization'].get('bits', '?')
    group = c['quantization'].get('group_size', '?')
    quant = f'{bits}-bit (group {group})'
elif c.get('quantization'):
    quant = str(c['quantization'])

fields = [
    ('Architecture', arch),
    ('Hidden size', hidden),
    ('Layers', layers),
    ('Attention heads', heads),
    ('Context length', ctx),
    ('Vocab size', vocab),
    ('Quantization', quant),
]

for label, val in fields:
    print(f'    {label:<20} {val}')
" "${config}"
  fi
}

cmd_ps() {
  if ! _gateway_pid &>/dev/null; then
    echo "mlx-server is not running."
    return 0
  fi

  local resp
  resp=$(_api GET "/_/ps") || { echo "Could not reach gateway."; exit 1; }

  python3 -c "
import json, sys

data = json.loads(sys.stdin.read())
models = data.get('models', [])

if not models:
    print('No models loaded.')
    sys.exit(0)

print(f\"{'NAME':<50}  {'TYPE':<10}  {'SIZE':>6}  {'STATUS':<12}  IDLE\")
print(f\"{'-'*50}  {'-'*10}  {'-'*6}  {'-'*12}  {'-'*6}\")

for m in models:
    name = m['model']
    mtype = m.get('type', 'llm')
    size = f\"{m.get('size_gb', 0):.0f}GB\" if m.get('size_gb') else '-'
    if m.get('ready'):
        status = '✅ running'
    elif m.get('loading'):
        status = '⏳ loading'
    elif m.get('failed'):
        status = '❌ failed'
    else:
        status = '❌ error'
    idle = m.get('idle', '-')
    print(f'{name:<50}  {mtype:<10}  {size:>6}  {status:<12}  {idle}')
" <<< "${resp}"
}

cmd_list() {
  if [[ ! -d "${HF_CACHE}" ]]; then
    echo "No models downloaded."
    return 0
  fi

  local found=0
  printf "%-50s  %8s  %s\n" "NAME" "SIZE" "MODIFIED"
  printf "%-50s  %8s  %s\n" "$(printf '%.0s-' {1..50})" "--------" "----------"

  for dir in "${HF_CACHE}"/models--*; do
    [[ -d "${dir}" ]] || continue
    local dir_name; dir_name=$(basename "${dir}")
    local model_id; model_id=$(echo "${dir_name}" | sed 's/^models--//' | sed 's/--/\//g')
    local size; size=$(du -sh "${dir}" 2>/dev/null | awk '{print $1}')
    local modified; modified=$(stat -f "%Sm" -t "%Y-%m-%d" "${dir}" 2>/dev/null || stat -c "%y" "${dir}" 2>/dev/null | cut -d' ' -f1)
    printf "%-50s  %8s  %s\n" "${model_id}" "${size}" "${modified}"
    found=$((found + 1))
  done

  if [[ ${found} -eq 0 ]]; then
    echo "No models downloaded. Pull one with: mlx-server pull <model>"
  fi
}

cmd_search() {
  local query="${*:-}"
  local limit=20
  local url="https://huggingface.co/api/models?author=mlx-community&sort=downloads&limit=${limit}"
  [[ -n "${query}" ]] && url="${url}&search=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(' '.join(sys.argv[1:])))" ${query})"

  echo "Searching mlx-community models${query:+ for \"${query}\"}..."
  echo ""

  local response
  if ! response=$(curl -sf --max-time 10 "${url}"); then
    echo "Error: Could not reach HuggingFace. Check your internet." >&2
    exit 1
  fi

  python3 -c "
import json, os, sys

data = json.loads(sys.stdin.read())
hf_cache = sys.argv[1]

def is_local(model_id):
    return os.path.isdir(os.path.join(hf_cache, 'models--' + model_id.replace('/', '--')))

def fmt(n):
    if n >= 1_000_000: return f'{n/1_000_000:.1f}M'
    if n >= 1_000: return f'{n/1_000:.0f}k'
    return str(n)

print(f\"{'NAME':<55}  {'DOWNLOADS':>9}  LOCAL\")
print(f\"{'-'*55}  {'-'*9}  {'-'*5}\")

for m in data:
    mid = m['id']
    dl = fmt(m.get('downloads', 0))
    local = '✅' if is_local(mid) else ''
    print(f'{mid:<55}  {dl:>9}  {local}')

print(f'\nShowing top {len(data)} results.')
print('Pull with: mlx-server pull <model>')
" "${HF_CACHE}" <<< "${response}"
}

cmd_logs() {
  local follow=false
  while [[ $# -gt 0 ]]; do
    case "${1}" in
      -f) follow=true; shift ;;
      *)  shift ;;
    esac
  done

  local log="${MLX_HOME}/gateway.log"
  [[ -f "${log}" ]] || { echo "No log file found."; exit 1; }
  [[ "${follow}" == true ]] && tail -f "${log}" || tail -50 "${log}"
}

cmd_stats() {
  if ! _gateway_pid &>/dev/null; then
    echo "mlx-server is not running."
    return 0
  fi

  local resp
  resp=$(_api GET "/_/metrics") || { echo "Could not reach gateway."; exit 1; }

  python3 -c "
import json, sys

data = json.loads(sys.stdin.read())
uptime = data.get('uptime_seconds', 0)
hours, rem = divmod(uptime, 3600)
mins, secs = divmod(rem, 60)
uptime_str = f'{hours}h {mins}m {secs}s' if hours else f'{mins}m {secs}s'

print(f'Uptime:          {uptime_str}')
print(f'Total requests:  {data[\"total_requests\"]}')
print(f'Total errors:    {data[\"total_errors\"]}')
print()

models = data.get('models', {})
if not models:
    print('No requests recorded yet.')
    sys.exit(0)

print(f\"{'MODEL':<45}  {'REQS':>6}  {'ERRORS':>6}  {'PROMPT':>8}  {'COMPLT':>8}  {'CACHED':>8}  {'AVG MS':>8}  {'MAX MS':>8}\")
print(f\"{'-'*45}  {'-'*6}  {'-'*6}  {'-'*8}  {'-'*8}  {'-'*8}  {'-'*8}  {'-'*8}\")

for model, s in sorted(models.items()):
    name = model[-45:] if len(model) > 45 else model
    cache_pct = f\"{100*s['cached_tokens']//s['prompt_tokens']}%\" if s['prompt_tokens'] > 0 else '-'
    print(f'{name:<45}  {s[\"requests\"]:>6}  {s[\"errors\"]:>6}  {s[\"prompt_tokens\"]:>8}  {s[\"completion_tokens\"]:>8}  {cache_pct:>8}  {s[\"latency_avg_ms\"]:>8.0f}  {s[\"latency_max_ms\"]:>8.0f}')
" <<< "${resp}"
}

cmd_requests() {
  if ! _gateway_pid &>/dev/null; then
    # Fall back to reading log file
    local req_log="${MLX_HOME}/requests.jsonl"
    [[ -f "${req_log}" ]] || { echo "No request log found."; exit 1; }
    echo "Recent requests (from log file):"
    tail -20 "${req_log}" | python3 -c "
import json, sys
for line in sys.stdin:
    try:
        r = json.loads(line)
        ts = r['ts'][11:19]
        print(f\"{ts}  {r['model']:<45}  {r.get('prompt_tokens',0):>6}pt  {r.get('completion_tokens',0):>6}ct  {r.get('latency_ms',0):>7.0f}ms  {'ERR' if r.get('error') else 'OK'}\")
    except Exception:
        pass
"
    return 0
  fi

  local n="${1:-20}"
  local resp
  resp=$(_api GET "/_/requests?n=${n}") || { echo "Could not reach gateway."; exit 1; }

  python3 -c "
import json, sys

data = json.loads(sys.stdin.read())
requests = data.get('requests', [])

if not requests:
    print('No requests recorded yet.')
    sys.exit(0)

print(f\"{'TIME':>8}  {'MODEL':<40}  {'PT':>6}  {'CT':>6}  {'CACHED':>6}  {'MS':>7}  STATUS\")
print(f\"{'-'*8}  {'-'*40}  {'-'*6}  {'-'*6}  {'-'*6}  {'-'*7}  {'-'*6}\")

for r in requests:
    ts = r['ts'][11:19]
    model = r['model'][-40:]
    pt = r.get('prompt_tokens', 0)
    ct = r.get('completion_tokens', 0)
    cached = r.get('cached_tokens', 0)
    ms = r.get('latency_ms', 0)
    status = '❌' if r.get('error') else '✅'
    stream = '~' if r.get('stream') else ' '
    print(f'{ts}  {model:<40}  {pt:>6}  {ct:>6}  {cached:>6}  {ms:>7.0f}  {status}{stream}')

print()
print(f'Showing {len(requests)} most recent. ~ = streaming request')
" <<< "${resp}"
}

cmd_chat() {
  local model=""
  local no_think=false
  local message=""

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --model|-m)   model="${2}"; shift 2 ;;
      --model=*)    model="${1#*=}"; shift ;;
      --no-think)   no_think=true; shift ;;
      -*)           echo "Unknown option: ${1}"; echo ""; echo "Usage: mlx-server chat [--model <model>] [--no-think] \"<message>\""; exit 1 ;;
      *)            message="${1}"; shift ;;
    esac
  done

  if [[ -z "${message}" ]]; then
    echo "Usage: mlx-server chat [--model <model>] [--no-think] \"<message>\""
    echo ""
    echo "Examples:"
    echo "  mlx-server chat \"What is the capital of France?\""
    echo "  mlx-server chat --model mlx-community/Qwen3-8B-4bit \"Explain quantum computing\""
    echo "  mlx-server chat --no-think \"Quick answer: 2+2?\""
    exit 1
  fi

  _ensure_gateway

  # If no model specified, use the first ready LLM
  if [[ -z "${model}" ]]; then
    local ps_resp
    ps_resp=$(_api GET "/_/ps") || { echo "Could not reach gateway."; exit 1; }
    model=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m.get('ready') and m.get('type', 'llm') == 'llm':
        print(m['model'])
        sys.exit(0)
sys.exit(1)
" <<< "${ps_resp}" 2>/dev/null) || {
      echo "No model loaded. Specify one with --model:"
      echo "  mlx-server chat --model mlx-community/Qwen3-8B-4bit \"${message}\""
      echo ""
      echo "Available models:"
      cmd_list
      exit 1
    }
  fi

  # Auto-pull if not cached
  local cache_dir; cache_dir=$(_model_cache_dir "${model}")
  if [[ ! -d "${cache_dir}" ]]; then
    echo "Model not found locally. Pulling first..."
    cmd_pull "${model}" || exit 1
  fi

  # Load model if not already running
  local ps_resp
  ps_resp=$(_api GET "/_/ps") || true
  if ! python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m['model'] == sys.argv[1] and m.get('ready'):
        sys.exit(0)
sys.exit(1)
" "${model}" <<< "${ps_resp}" 2>/dev/null; then
    _api POST "/_/load" "{\"model\":\"${model}\"}" > /dev/null
    echo -n "Loading ${model}"
    local loaded=false
    for _ in $(seq 1 200); do
      ps_resp=$(_api GET "/_/ps") || { sleep 3; echo -n "."; continue; }
      local failed_err
      failed_err=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m['model'] == sys.argv[1] and m.get('failed'):
        print(m.get('error', 'Unknown error'))
        sys.exit(0)
sys.exit(1)
" "${model}" <<< "${ps_resp}" 2>/dev/null) && {
        echo ""
        echo "❌ Failed to load ${model}: ${failed_err}" >&2
        exit 1
      }
      if python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for m in data.get('models', []):
    if m['model'] == sys.argv[1] and m.get('ready'):
        sys.exit(0)
sys.exit(1)
" "${model}" <<< "${ps_resp}" 2>/dev/null; then
        echo ""
        loaded=true
        break
      fi
      sleep 3; echo -n "."
    done
    [[ "${loaded}" == false ]] && { echo ""; echo "❌ Timed out loading model." >&2; exit 1; }
  fi

  # Optionally prefix message to disable thinking (Qwen3 style)
  local final_message="${message}"
  [[ "${no_think}" == true ]] && final_message="/no_think ${message}"

  # Stream the response
  python3 - "${GATEWAY_URL}" "${model}" "${final_message}" << 'PYEOF'
import sys, json, urllib.request, urllib.error

base_url, model, message = sys.argv[1], sys.argv[2], sys.argv[3]
body = json.dumps({
    "model": model,
    "messages": [{"role": "user", "content": message}],
    "stream": True,
    "stream_options": {"include_usage": True},
}).encode()

req = urllib.request.Request(
    f"{base_url}/v1/chat/completions",
    data=body,
    headers={"Content-Type": "application/json", "Content-Length": str(len(body))},
)

in_thinking = False
try:
    with urllib.request.urlopen(req, timeout=300) as resp:
        for raw_line in resp:
            line = raw_line.decode().strip()
            if not line.startswith("data: "):
                continue
            data_str = line[6:]
            if data_str == "[DONE]":
                break
            try:
                chunk = json.loads(data_str)
                if not chunk.get("choices"):
                    continue
                delta = chunk["choices"][0].get("delta", {})
                reasoning = delta.get("reasoning_content", "")
                content = delta.get("content", "")
                if reasoning:
                    if not in_thinking:
                        sys.stdout.write("\033[2m")  # dim
                        sys.stdout.flush()
                        in_thinking = True
                    sys.stdout.write(reasoning)
                    sys.stdout.flush()
                elif content:
                    if in_thinking:
                        sys.stdout.write("\033[0m\n")  # reset + newline after thinking
                        sys.stdout.flush()
                        in_thinking = False
                    sys.stdout.write(content)
                    sys.stdout.flush()
            except json.JSONDecodeError:
                pass
except KeyboardInterrupt:
    pass
except urllib.error.HTTPError as e:
    body = e.read().decode()
    try:
        err = json.loads(body)
        print(f"\n\033[31mError: {err.get('error', body)}\033[0m", file=sys.stderr)
    except Exception:
        print(f"\n\033[31mError ({e.code}): {body}\033[0m", file=sys.stderr)
    sys.exit(1)

if in_thinking:
    sys.stdout.write("\033[0m")
print()
PYEOF
}

cmd_shutdown() {
  local pid
  pid=$(_gateway_pid) || { echo "mlx-server is not running."; return 0; }

  echo "Shutting down mlx-server (PID ${pid})..."
  kill "${pid}"

  # Wait for clean exit
  for _ in $(seq 1 10); do
    kill -0 "${pid}" 2>/dev/null || { echo "✅ Stopped."; return 0; }
    sleep 1
  done
  echo "✅ Stopped."
}

print_usage() {
  cat <<EOF
Usage: mlx-server <command> [options]

Server:
  serve [--port N]              Start the mlx-server gateway  (default: ${GATEWAY_PORT})
  shutdown                      Stop the gateway and all loaded models

Models:
  run <model>                   Load a model and start interactive chat
  chat [--model <m>] "<msg>"   Send a single message and get a response
  stop <model>                  Unload a model from memory
  pull <model>                  Download a model from HuggingFace
  rm <model>                    Delete a downloaded model
  show <model>                  Show model details

Info:
  ps                            List currently loaded models
  list                          List locally downloaded models
  search [query]                Search mlx-community models on HuggingFace
  logs [-f]                     View gateway logs
  stats                         Show request metrics (tokens, latency, cache hits)
  requests [n]                  Show recent requests (default: last 20)

Environment:
  MLX_PORT                      Gateway port (default: 11070)

Examples:
  mlx-server serve
  mlx-server pull mlx-community/Qwen3-32B-4bit
  mlx-server run mlx-community/Qwen3-32B-4bit
  mlx-server run mlx-community/Qwen3-8B-4bit
  mlx-server chat "What is the capital of France?"
  mlx-server chat --model mlx-community/Qwen3-8B-4bit "Explain recursion"
  mlx-server chat --no-think "Quick: 2+2?"
  mlx-server ps
  mlx-server stop mlx-community/Qwen3-8B-4bit
  mlx-server search llama
  mlx-server shutdown

API (single endpoint, multiple models):
  curl http://127.0.0.1:${GATEWAY_PORT}/v1/chat/completions \\
    -H "Content-Type: application/json" \\
    -d '{"model":"mlx-community/Qwen3-32B-4bit","messages":[{"role":"user","content":"Hello"}]}'
EOF
}

# ── Entry point ──────────────────────────────────────────────────────────────
case "${1:-}" in
  serve)      shift; cmd_serve "$@" ;;
  run)        shift; cmd_run "$@" ;;
  chat)       shift; cmd_chat "$@" ;;
  stop)       shift; cmd_stop "$@" ;;
  pull)       shift; cmd_pull "$@" ;;
  rm|remove)  shift; cmd_rm "$@" ;;
  show)       shift; cmd_show "$@" ;;
  ps)         shift; cmd_ps ;;
  list|ls)    shift; cmd_list ;;
  search)     shift; cmd_search "$@" ;;
  logs)       shift; cmd_logs "$@" ;;
  stats)      shift; cmd_stats ;;
  requests)   shift; cmd_requests "$@" ;;
  shutdown)   shift; cmd_shutdown ;;
  -h|--help|help|"") print_usage ;;
  *)          echo "Unknown command: ${1}"; echo ""; print_usage; exit 1 ;;
esac
